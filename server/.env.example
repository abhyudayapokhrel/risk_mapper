# ═══════════════════════════════════════════════════════
# RiskMapper Nepal — Backend Environment Variables
# ═══════════════════════════════════════════════════════
#
# Generate your own VAPID keys with:
#   npx web-push generate-vapid-keys
#
# Then paste the values below and rename this file to .env

VAPID_PUBLIC_KEY=your_public_key_here
VAPID_PRIVATE_KEY=your_private_key_here
VAPID_SUBJECT=mailto:riskmapper@example.com

# Server port (default: 3000)
PORT=3000

# USGS polling interval in milliseconds (default: 60000 = 60s)
USGS_POLL_INTERVAL=60000
